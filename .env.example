# Postgres
DATABASE_URL=postgres://fishhub:fishhub@localhost:5432/fishhub?sslmode=disable
PORT=8080

# InfluxDB 3 Core
# Token must start with apiv3_ — choose any value for local dev
INFLUXDB3_HOST=http://localhost:8181
INFLUXDB3_TOKEN=apiv3_changeme
INFLUXDB3_DATABASE=readings

# Grafana
GRAFANA_PASSWORD=admin

# OAuth / session JWT
GOOGLE_CLIENT_ID=
JWT_SECRET=change-me-to-a-random-32-plus-byte-secret
JWT_TTL_HOURS=24
